# This repo builds a Rubygem. No lock file then.
Gemfile.lock

# Don't commit the temporary directory used by tests in debug mode
.cline_test

# On Windows, node-pty is used to execute the CLI.
# Don't commit node package files and modules.
node_modules
package.json
package-lock.json

# Yard is used to generate doc. Don't commit generated yard files.
.yardoc/
doc/

# SimpleCov is used to generate code coverage reports. Don't commit generated coverage files.
coverage/
